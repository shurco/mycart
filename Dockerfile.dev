# Development Dockerfile for myCart with PortOne integration
# This builds the application from source with all your changes

# Stage 1: Build Frontend (Admin)
FROM node:20-alpine AS admin-builder
WORKDIR /app/web/admin

# Install dependencies
COPY web/admin/package*.json web/admin/bun.lockb ./
RUN npm install || bun install || true

# Copy admin source
COPY web/admin ./

# Build admin frontend
RUN npm run build || bun run build || true

# Stage 2: Build Frontend (Site)
FROM node:20-alpine AS site-builder
WORKDIR /app/web/site

# Install dependencies
COPY web/site/package*.json web/site/bun.lockb ./
RUN npm install || bun install || true

# Copy site source
COPY web/site ./

# Build site frontend
RUN npm run build || bun run build || true

# Stage 3: Build Go Backend
FROM golang:1.23-alpine AS go-builder
WORKDIR /app

# Install build dependencies
RUN apk add --no-cache git ca-certificates tzdata

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Copy built frontends
COPY --from=admin-builder /app/web/admin/build ./web/admin/build
COPY --from=site-builder /app/web/site/build ./web/site/build

# Build the application
RUN CGO_ENABLED=0 GOOS=linux go build -installsuffix cgo -ldflags="-w -s" -o mycart ./cmd

# Stage 4: Final Runtime Image
FROM alpine:latest

# Install runtime dependencies
RUN apk --no-cache add ca-certificates tzdata sqlite

WORKDIR /root/

# Copy the binary
COPY --from=go-builder /app/mycart .

# Copy migrations (embedded in binary, but good to have)
COPY --from=go-builder /app/migrations ./migrations

# Expose port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8080/ping || exit 1

# Run the application
ENTRYPOINT ["./mycart"]
CMD ["serve"]
