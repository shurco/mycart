    "happy-dom": "^20.11.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "tailwindcss": "4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "webdriverio": "^9.30.0"
