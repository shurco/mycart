    "@tiptap/pm": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "isomorphic-dompurify": "^3.18.0",
    "nprogress": "^0.2.0",
    "svelte": "^5.56.4",
    "svelte-french-toast": "^1.2.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/vite": "^4.3.2",
